# Backend Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5115
ConnectionStrings__DefaultConnection=Data Source=transactiondispute.db

# Frontend Configuration
VITE_API_URL=http://localhost:5115/api

# Docker Configuration (for docker-compose)
DATABASE_PATH=/app/data/transactiondispute.db
# Set a strong password for the Postgres container. Do NOT commit this file with a real password.
POSTGRES_PASSWORD=change-me
# Optional: pgAdmin password
PGADMIN_PASSWORD=change-me
# JWT key for signing tokens (override in environment for production)
JWT_KEY=change-me-super-secret
